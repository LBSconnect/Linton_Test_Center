# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit real secrets.

# App base URL (default: http://localhost:5000)
BASE_URL=http://localhost:5000

# Postgres connection string — use a dedicated TEST database, not production
DATABASE_URL=postgresql://user:password@localhost:5432/lbs_test

# Stripe TEST mode keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — run: stripe listen --print-secret
# Paste the output here (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_...
